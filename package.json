{
  "name": "project-command-center",
  "displayName": "Colin's Project Command Center",
  "description": "A VS Code sidebar for project scripts, Git context, health checks, quick actions, and workspace shortcuts.",
  "version": "0.1.0",
  "publisher": "ColinGamez",
  "license": "MIT",
  "main": "./extension.js",
  "activationEvents": [
    "onView:project-command-center.view",
    "onCommand:project-command-center.open",
    "onCommand:project-command-center.refresh",
    "onCommand:project-command-center.runScript",
    "onCommand:project-command-center.runBestScript",
    "onCommand:project-command-center.openTerminal",
    "onCommand:project-command-center.openFile",
    "onCommand:project-command-center.openOrCreateFile",
    "onCommand:project-command-center.openRepository",
    "onCommand:project-command-center.createMissingBasics"
  ],
  "extensionKind": [
    "ui"
  ],
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#180602",
    "theme": "dark"
  },
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/ColinGamez/Project-Command-Center.git"
  },
  "homepage": "https://github.com/ColinGamez/Project-Command-Center#readme",
  "bugs": {
    "url": "https://github.com/ColinGamez/Project-Command-Center/issues"
  },
  "scripts": {
    "build": "node scripts/check-package.mjs"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "command center",
    "sidebar",
    "scripts",
    "project health",
    "git",
    "terminal",
    "workspace",
    "developer tools",
    "vs code"
  ],
  "contributes": {
    "commands": [
      {
        "command": "project-command-center.open",
        "title": "Open Project Command Center",
        "category": "Colin's Project Command Center"
      },
      {
        "command": "project-command-center.refresh",
        "title": "Refresh Project Command Center",
        "category": "Colin's Project Command Center"
      },
      {
        "command": "project-command-center.runBestScript",
        "title": "Run Best Project Script",
        "category": "Colin's Project Command Center"
      },
      {
        "command": "project-command-center.openTerminal",
        "title": "Open Project Terminal",
        "category": "Colin's Project Command Center"
      },
      {
        "command": "project-command-center.openRepository",
        "title": "Open Project Repository",
        "category": "Colin's Project Command Center"
      },
      {
        "command": "project-command-center.createMissingBasics",
        "title": "Create Missing Project Basics",
        "category": "Colin's Project Command Center"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "project-command-center",
          "title": "Command Center",
          "icon": "assets/logo-mark.png"
        }
      ]
    },
    "views": {
      "project-command-center": [
        {
          "id": "project-command-center.view",
          "name": "Command Center"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "project-command-center.refresh",
          "when": "view == project-command-center.view",
          "group": "navigation"
        }
      ]
    }
  }
}
